---
import { ClientRouter } from 'astro:transitions';
import AuthGuard from '../components/AuthGuard';
import '../styles/global.css';

export interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="RobiPet - Gestión de salud de mascotas" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ClientRouter />
		<script is:inline>
			(function() {
				const locale = localStorage.getItem('locale') || 'en';
				const titles = {
					es: 'RobiPet - Inicio',
					en: 'RobiPet - Home'
				};
				document.title = titles[locale] || titles.en;
			})();
		</script>
	</head>
	<body class="min-h-screen bg-slate-900 text-white flex flex-col">
		<AuthGuard client:load>
			<slot />
		</AuthGuard>
	</body>
</html>
<style is:global>
	html {
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
	}

	* {
		box-sizing: border-box;
	}

	astro-island {
		display: contents;
	}

	/* View Transitions - instant swap without flashing */
	::view-transition-old(root),
	::view-transition-new(root) {
		animation: none;
		mix-blend-mode: normal;
	}

	::view-transition-old(root) {
		z-index: 1;
	}

	::view-transition-new(root) {
		z-index: 9999;
	}

	/* Prevent background flash during transition */
	html {
		background-color: #0f172a; /* slate-900 */
	}
</style>
